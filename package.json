{
  "name": "fitflow",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered fitness platform for Indian users",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build:client": "cd client && npm run build",
    "migrate": "cd server && npx knex migrate:latest",
    "migrate:rollback": "cd server && npx knex migrate:rollback",
    "seed": "cd server && npx knex seed:run",
    "setup": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
