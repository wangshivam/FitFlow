    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "pg": "^8.21.0",
    "razorpay": "^2.9.6",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
